<style>
/* Settings form inside cards — override WP defaults */
.advstats-card .form-table { margin: 0; }
.advstats-card .form-table th {
    padding: 14px 12px 14px 0;
    font-weight: 600;
    font-size: 13px;
    color: var(--advstats-text);
    vertical-align: top;
    width: 200px;
}
.advstats-card .form-table td {
    padding: 14px 0;
    font-size: 13px;
}
.advstats-card .form-table td p.description {
    font-size: 12px;
    color: var(--advstats-text-secondary);
    margin-top: 4px;
}
.advstats-card .form-table input[type="text"],
.advstats-card .form-table input[type="number"],
.advstats-card .form-table textarea,
.advstats-card .form-table select {
    border-radius: 8px;
    border: 1px solid var(--advstats-border);
    padding: 6px 12px;
    font-size: 13px;
    transition: border-color 0.2s, box-shadow 0.2s;
}
.advstats-card .form-table input:focus,
.advstats-card .form-table select:focus,
.advstats-card .form-table textarea:focus {
    border-color: var(--advstats-primary);
    box-shadow: 0 0 0 2px rgba(108, 99, 255, 0.15);
    outline: none;
}
.advstats-card .form-table input[type="checkbox"],
.advstats-card .form-table input[type="radio"] {
    accent-color: var(--advstats-primary);
}
.advstats-card .form-table fieldset label {
    display: block;
    margin-bottom: 6px;
    font-size: 13px;
}
</style>
