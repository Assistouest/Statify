<?php
/**
 * Settings view template — Advanced Stats v1.1.0.
 * Redesigned: card-based layout matching the dashboard style.
 *
 * @package AdvStats
 */

if ( ! defined( 'ABSPATH' ) ) {
    exit;
}

$options = get_option( 'advstats_options', array() );

// ── Stats rapides pour le panneau maintenance ────────────────────────────────
global $wpdb;
$total_hits     = (int) $wpdb->get_var( "SELECT COUNT(*) FROM {$wpdb->prefix}advstats_hits" ); // phpcs:ignore
$total_sessions = (int) $wpdb->get_var( "SELECT COUNT(*) FROM {$wpdb->prefix}advstats_sessions" ); // phpcs:ignore
$total_scroll   = 0;
if ( $wpdb->get_var( $wpdb->prepare( 'SHOW TABLES LIKE %s', $wpdb->prefix . 'advstats_scroll' ) ) ) {
    $total_scroll = (int) $wpdb->get_var( "SELECT COUNT(*) FROM {$wpdb->prefix}advstats_scroll" ); // phpcs:ignore
}
$total_daily    = (int) $wpdb->get_var( "SELECT COUNT(*) FROM {$wpdb->prefix}advstats_daily" ); // phpcs:ignore
$anon_hits      = (int) $wpdb->get_var( "SELECT COUNT(*) FROM {$wpdb->prefix}advstats_hits WHERE visitor_hash LIKE 'anon_%'" ); // phpcs:ignore
$tracking_mode  = isset( $options['tracking_mode'] ) ? $options['tracking_mode'] : 'cookieless';
$retention      = isset( $options['retention_days'] ) ? absint( $options['retention_days'] ) : 90;
?>
<div class="wrap advstats-wrap">

    <!-- ── Header ──────────────────────────────────────────────────────────── -->
    <div class="advstats-header">
        <h1>
            <img src="<?php echo esc_url( ADVSTATS_PLUGIN_URL . 'Statify.svg' ); ?>"
                 alt="Statify" style="width:32px;height:32px;vertical-align:middle;">
            <?php esc_html_e( 'Statify — Réglages', 'adv-stats' ); ?>
        </h1>
        <div class="advstats-header-actions">
            <span style="font-size:12px;color:var(--advstats-text-secondary);">v<?php echo esc_html( ADVSTATS_VERSION ); ?></span>
        </div>
    </div>

    <form method="post" action="options.php" id="advstats-settings-form">
        <?php settings_fields( 'advstats_settings' ); ?>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- RGPD STATUS BANNER                                               -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <div class="advstats-card" style="border-left:4px solid var(--advstats-primary);margin-bottom:24px;">
