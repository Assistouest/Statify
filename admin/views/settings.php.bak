                <div style="font-size:32px;">🛡️</div>
                <div style="flex:1;min-width:240px;">
                    <div style="font-size:15px;font-weight:700;color:var(--advstats-text);margin-bottom:4px;">
                        <?php esc_html_e( 'Statut RGPD', 'adv-stats' ); ?>
                    </div>
                    <div style="font-size:13px;color:var(--advstats-text-secondary);line-height:1.5;">
                        <?php if ( 'cookie' === $tracking_mode ) : ?>
                            <?php esc_html_e( 'Mode cookie actif — le consentement est requis pour le tracking.', 'adv-stats' ); ?>
                        <?php else : ?>
                            <?php esc_html_e( 'Mode sans cookie — identification par hash journalier (IP+UA). Exemption CNIL possible pour mesure d\'audience.', 'adv-stats' ); ?>
                        <?php endif; ?>
                    </div>
                </div>
                <div style="display:flex;gap:12px;flex-wrap:wrap;">
                    <div style="background:<?php echo ! empty( $options['anonymize_ip'] ) ? 'rgba(16,185,129,0.1)' : 'rgba(239,68,68,0.1)'; ?>;padding:6px 14px;border-radius:20px;font-size:12px;font-weight:600;color:<?php echo ! empty( $options['anonymize_ip'] ) ? 'var(--advstats-success)' : 'var(--advstats-danger)'; ?>;">
                        <?php echo ! empty( $options['anonymize_ip'] ) ? '✅ ' : '⚠️ '; ?>
                        <?php esc_html_e( 'IP anonymisée', 'adv-stats' ); ?>
                    </div>
                    <div style="background:rgba(108,99,255,0.1);padding:6px 14px;border-radius:20px;font-size:12px;font-weight:600;color:var(--advstats-primary);">
                        🗓️ <?php echo 0 === $retention ? esc_html__( 'Rétention illimitée', 'adv-stats' ) : sprintf( esc_html__( 'Rétention %d jours', 'adv-stats' ), $retention ); ?>
                    </div>
                    <div style="background:rgba(16,185,129,0.1);padding:6px 14px;border-radius:20px;font-size:12px;font-weight:600;color:var(--advstats-success);">
                        🔒 <?php esc_html_e( 'Anonymisation auto', 'adv-stats' ); ?>
                    </div>
                </div>
            </div>
        </div>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- TRACKING                                                          -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <div class="advstats-card" style="margin-bottom:24px;">
            <div class="advstats-card-header">
                <h2>📊 <?php esc_html_e( 'Tracking', 'adv-stats' ); ?></h2>
            </div>
            <div class="advstats-card-body">
                <?php do_settings_fields( 'advstats-settings', 'advstats_general' ); ?>
            </div>
        </div>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- CONFIDENTIALITÉ & RGPD                                            -->
