                ✅ <?php printf( esc_html__( '%s hits ont été anonymisés. Leurs statistiques sont conservées mais ne sont plus liables à un individu.', 'adv-stats' ), '<strong>' . esc_html( number_format_i18n( $anon_hits ) ) . '</strong>' ); ?>
            </div>
            <?php endif; ?>

            <div style="display:flex;gap:12px;flex-wrap:wrap;">
                <button id="advstats-purge-btn" class="button button-secondary"
                        onclick="return confirm('<?php esc_attr_e( 'Cela va anonymiser les données plus anciennes que la période de rétention et consolider les agrégats. Continuer ?', 'adv-stats' ); ?>');"
