        <div class="advstats-card" style="margin-bottom:24px;border-left:4px solid var(--advstats-success);">
            <div class="advstats-card-header">
                <h2>🔐 <?php esc_html_e( 'Confidentialité & RGPD', 'adv-stats' ); ?></h2>
            </div>
            <div class="advstats-card-body">
                <?php do_settings_fields( 'advstats-settings', 'advstats_privacy' ); ?>

                <div style="margin-top:20px;padding:16px;background:#f0fdf4;border-radius:8px;border:1px solid #bbf7d0;">
                    <div style="font-size:13px;font-weight:600;color:#166534;margin-bottom:6px;">
                        💡 <?php esc_html_e( 'Comment fonctionne l\'anonymisation', 'adv-stats' ); ?>
                    </div>
                    <div style="font-size:12px;color:#15803d;line-height:1.6;">
                        <?php esc_html_e( 'Après la période de rétention, les données ne sont PAS supprimées — elles sont anonymisées. Le visitor_hash est remplacé par un hash aléatoire, le user_id est effacé, le referrer est réduit au domaine. Les métriques statistiques (durée, scroll, device, page) sont conservées indéfiniment. Les comptages (UV, sessions) sont figés dans les agrégats journaliers AVANT anonymisation.', 'adv-stats' ); ?>
                    </div>
                </div>
            </div>
        </div>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- CONSENTEMENT                                                      -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <div class="advstats-card" style="margin-bottom:24px;">
            <div class="advstats-card-header">
                <h2>✋ <?php esc_html_e( 'Bannière de consentement', 'adv-stats' ); ?></h2>
                <?php if ( 'cookieless' === $tracking_mode ) : ?>
                    <span style="background:rgba(245,158,11,0.1);color:#b45309;padding:4px 12px;border-radius:16px;font-size:11px;font-weight:600;">
                        <?php esc_html_e( 'Mode sans cookie — bannière optionnelle', 'adv-stats' ); ?>
                    </span>
                <?php else : ?>
                    <span style="background:rgba(239,68,68,0.1);color:#dc2626;padding:4px 12px;border-radius:16px;font-size:11px;font-weight:600;">
                        <?php esc_html_e( 'Mode cookie — bannière recommandée', 'adv-stats' ); ?>
                    </span>
                <?php endif; ?>
            </div>
            <div class="advstats-card-body">
                <?php do_settings_fields( 'advstats-settings', 'advstats_consent' ); ?>
            </div>
        </div>

        <!-- ══════════════════════════════════════════════════════════════════ -->
