        </div>

        <!-- SAVE BUTTON -->
        <div style="margin-bottom:24px;">
            <?php submit_button( __( 'Enregistrer les réglages', 'adv-stats' ), 'primary large', 'submit', false, array( 'style' => 'background:var(--advstats-primary);border-color:var(--advstats-primary-dark);border-radius:8px;padding:8px 32px;font-size:14px;' ) ); ?>
        </div>
    </form>

    <!-- ══════════════════════════════════════════════════════════════════ -->
